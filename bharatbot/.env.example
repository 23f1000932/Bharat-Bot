# =============================================================================
# BharatBot – Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit your real .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Azure OpenAI (GPT-4o-mini)
# Get from: Azure Portal > Your OpenAI Resource > Keys and Endpoint
# -----------------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_KEY=your-azure-openai-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# -----------------------------------------------------------------------------
# Azure AI Foundry Project (Agent Service)
# Get from: Azure AI Studio > Your Project > Overview > Project connection string
# Agent IDs are created after you set up agents in Azure AI Foundry.
# -----------------------------------------------------------------------------
FOUNDRY_PROJECT_ENDPOINT=https://your-project.api.azureml.ms
AGRIBOT_AGENT_ID=asst_xxxxxxxxxxxxxxxxxxxx
HEALTHBOT_AGENT_ID=asst_xxxxxxxxxxxxxxxxxxxx
LAWBOT_AGENT_ID=asst_xxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Azure Cognitive Services Speech (STT + TTS)
# Get from: Azure Portal > Your Speech Resource > Keys and Endpoint
# Region examples: centralindia, eastus, westeurope
# -----------------------------------------------------------------------------
SPEECH_KEY=your-speech-service-key-here
SPEECH_REGION=centralindia

# -----------------------------------------------------------------------------
# Azure Translator API
# Get from: Azure Portal > Your Translator Resource > Keys and Endpoint
# The endpoint is typically the global one shown below.
# -----------------------------------------------------------------------------
TRANSLATOR_KEY=your-translator-key-here
TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com

# -----------------------------------------------------------------------------
# Azure AI Search
# Get from: Azure Portal > Your Search Resource > Keys > Admin key
# Index names must match what your upload_knowledge.py script creates.
# -----------------------------------------------------------------------------
SEARCH_ENDPOINT=https://your-search-service.search.windows.net
SEARCH_KEY=your-search-admin-key-here
SEARCH_INDEX_AGRI=agribot-knowledge
SEARCH_INDEX_HEALTH=healthbot-knowledge
SEARCH_INDEX_LAW=lawbot-knowledge

# -----------------------------------------------------------------------------
# Meta WhatsApp Cloud API
# Get from: developers.facebook.com > Your App > WhatsApp > API Setup
# WA_VERIFY_TOKEN is a secret string YOU choose for webhook verification.
# -----------------------------------------------------------------------------
WA_TOKEN=your-meta-whatsapp-token-here
WA_PHONE_ID=your-whatsapp-phone-number-id
WA_VERIFY_TOKEN=bharatbot_webhook_2024
