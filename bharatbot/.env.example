# ============================================================
# BharatBot Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual keys.
# ============================================================

# --- Google Gemini API (LLM backend) ---
# Get your key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- Azure Speech Service (STT + TTS) ---
# Create a Speech resource in Azure Portal → Keys and Endpoint
SPEECH_KEY=
SPEECH_REGION=centralindia

# --- Azure Translator API (language detection) ---
# Create a Translator resource in Azure Portal → Keys and Endpoint
TRANSLATOR_KEY=
TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com
TRANSLATOR_REGION=global

# --- Azure AI Search (knowledge base) ---
# Create a Search service in Azure Portal → Keys
SEARCH_ENDPOINT=
SEARCH_KEY=
SEARCH_INDEX_AGRI=agribot-knowledge
SEARCH_INDEX_HEALTH=healthbot-knowledge
SEARCH_INDEX_LAW=lawbot-knowledge

# --- WhatsApp Business API (optional) ---
# Create a Meta Business app → WhatsApp → API Setup
WA_TOKEN=
WA_PHONE_ID=
WA_VERIFY_TOKEN=bharatbot_webhook_2024
